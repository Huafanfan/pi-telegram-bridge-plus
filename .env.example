# Let this .env file override same-name variables already exported in your shell.
# Default behavior is override=true. Set DOTENV_OVERRIDE=false to disable.
DOTENV_OVERRIDE=true

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:replace-me

# Legacy comma-separated numeric private chat IDs allowed to control the bot.
# Kept for backwards compatibility. For private DMs, your chat ID is usually your user ID.
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# New identity-aware access controls. Recommended for group/topic use.
# TELEGRAM_ALLOWED_USER_IDS=123456789
# TELEGRAM_ALLOWED_GROUP_IDS=-1001234567890
# TELEGRAM_OWNER_USER_IDS=123456789
# TELEGRAM_APPROVER_USER_IDS=123456789
TELEGRAM_GROUP_REQUIRE_MENTION=true
# Optional comma/newline separated regex wake phrases for groups.
# TELEGRAM_MENTION_PATTERNS=^\s*pi\b

# Optional UX signals.
TELEGRAM_ENABLE_TYPING=true
TELEGRAM_ENABLE_REACTIONS=false
TELEGRAM_SEND_RETRIES=3
TELEGRAM_SEND_RETRY_BASE_MS=750
# Optional explicit Telegram API proxy for grammY API calls and file downloads.
# Standard HTTPS_PROXY/HTTP_PROXY/ALL_PROXY may also work depending on runtime.
# Example: TELEGRAM_PROXY=http://127.0.0.1:6152
TELEGRAM_PROXY=
# Optional custom Telegram Bot API roots. Do not include trailing slash.
TELEGRAM_API_ROOT=https://api.telegram.org
TELEGRAM_FILE_API_ROOT=https://api.telegram.org/file

# Optional dynamic pairing. Paired users are stored locally; keep this file private.
TELEGRAM_PAIRING_ENABLED=false
TELEGRAM_PAIRING_FILE=.telegram-pairing.json
TELEGRAM_PAIRING_CODE_TTL_MS=600000

# Only run pi inside this workspace directory.
WORKSPACE_ROOT=/Users/you/Workspace

# pi executable and optional extra args.
PI_BIN=pi
# PI_ARGS=--no-extensions

# Optional pi model settings. These are appended to PI_ARGS.
# PI_PROVIDER=openai
# PI_MODEL=gpt-5.5
# PI_THINKING=medium
# PI_SESSION_DIR=/Users/you/.pi/telegram-sessions

# Telegram input/output controls.
MAX_TELEGRAM_CHARS=3500
MAX_IMAGE_BYTES=8000000
MAX_DOCUMENT_BYTES=10000000
MAX_VOICE_BYTES=20000000
MAX_ALBUM_IMAGES=10
MAX_OUTBOUND_FILE_BYTES=20000000

# Voice transcription command hook. The downloaded .ogg path is appended as the final arg.
# Example: VOICE_TRANSCRIBE_CMD="whisper-cli --model base --file"
# VOICE_TRANSCRIBE_CMD=

# Chat UX defaults: quiet, chat-like replies.
# Set VERBOSE_EVENTS=true to show pi started/finished/tool events.
# Set SHOW_CONTROL_BUTTONS=true to attach Status/New/Abort buttons to bot messages.
VERBOSE_EVENTS=false
SHOW_CONTROL_BUTTONS=false

TOOL_UPDATE_THROTTLE_MS=1200
TEXT_UPDATE_THROTTLE_MS=1200
ALBUM_DEBOUNCE_MS=850
TYPING_INTERVAL_MS=4500

# Optional session cleanup. 0 disables automatic cleanup.
# Example: close idle non-streaming sessions after 2 hours.
SESSION_IDLE_TIMEOUT_MS=0
SESSION_IDLE_SWEEP_MS=60000

# Optional local healthcheck endpoint for service managers. Disabled when port is 0.
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=0
HEALTHCHECK_PATH=/healthz

# Optional webhook mode. Long polling is used when TELEGRAM_WEBHOOK_URL is empty.
# TELEGRAM_WEBHOOK_URL=https://example.com
# TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=0
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_MAX_BODY_BYTES=2000000
