{
  "name": "pi-telegram-bridge-plus",
  "version": "0.1.0",
  "description": "Telegram bridge for pi coding agent RPC mode",
  "main": "dist/index.js",
  "scripts": {
    "test": "npm run build && node --test dist/**/*.test.js",
    "prepublishOnly": "npm test",
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "keywords": [
    "pi",
    "telegram",
    "coding-agent",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pi-telegram-bridge-plus": "./dist/index.js",
    "pi-telegram-bridge": "./dist/index.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "grammy": "^1.42.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "DEPLOY.md",
    "examples"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Huafanfan/pi-telegram-bridge-plus.git"
  },
  "bugs": {
    "url": "https://github.com/Huafanfan/pi-telegram-bridge-plus/issues"
  },
  "homepage": "https://github.com/Huafanfan/pi-telegram-bridge-plus#readme"
}
